    "import time\n",
    "from datetime import datetime\n",
    "\n",
    "end = time.time() + 24 * 60 * 60  # 5 hours\n",
    "\n",
    "while time.time() < end:\n",
    "    print(f\"Cluster keep-alive ping: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n",
    "    spark.range(1).count()\n",
    "    time.sleep(600)  # 10 minutes"
